<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Apple Privacy Manifest — Strand Descent
  TDD §17.4 / T-17

  Declared data types match TDD §17.1 exactly.
  Required Reason API declarations cover Capacitor's use of NSUserDefaults
  (Preferences plugin) and file-timestamp reads (Filesystem plugin).

  Review against https://developer.apple.com/documentation/bundleresources/privacy_manifest_files
  before App Store submission, and re-audit whenever a new Capacitor plugin is added.
-->
<plist version="1.0">
<dict>

  <!-- ── Tracking ─────────────────────────────────────────────────────── -->
  <!-- We do not track users across apps or websites owned by other companies. -->
  <key>NSPrivacyTracking</key>
  <false/>

  <key>NSPrivacyTrackingDomains</key>
  <array/>

  <!-- ── Collected Data Types ──────────────────────────────────────────── -->
  <key>NSPrivacyCollectedDataTypes</key>
  <array>

    <!-- Device or other identifiers: Firebase anonymous UID -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeDeviceID</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>   <!-- UID is anonymous; not linked to real identity -->
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
        <!-- Cloud save sync, run-state restoration -->
      </array>
    </dict>

    <!-- Crash data: Firebase Crashlytics stack traces -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeCrashData</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- Performance data: frame timing, session duration, cold-start time -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypePerformanceData</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- Other app usage data: gameplay telemetry (mutation builds, floor depth,
         death causes, run duration). Anonymized and aggregated. -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeOtherUsageData</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
      </array>
    </dict>

    <!-- Purchase history: hashed IAP receipt tokens, server-validated only -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypePurchaseHistory</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

  </array>

  <!-- ── Required Reason APIs ──────────────────────────────────────────── -->
  <key>NSPrivacyAccessedAPITypes</key>
  <array>

    <!-- NSUserDefaults: used by @capacitor/preferences for local game settings
         and lightweight key-value storage (e.g. consent flag, tutorial-skip flag).
         Reason CA92.1 — access info from the same app on the same device. -->
    <dict>
      <key>NSPrivacyAccessedAPIType</key>
      <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
      <key>NSPrivacyAccessedAPITypeReasons</key>
      <array>
        <string>CA92.1</string>
      </array>
    </dict>

    <!-- File timestamp APIs: used by @capacitor/filesystem when reading/writing
         save files. Capacitor accesses file modification dates for cache validation.
         Reason C617.1 — provide app's primary functionality (save/load game state). -->
    <dict>
      <key>NSPrivacyAccessedAPIType</key>
      <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
      <key>NSPrivacyAccessedAPITypeReasons</key>
      <array>
        <string>C617.1</string>
      </array>
    </dict>

  </array>

</dict>
</plist>
