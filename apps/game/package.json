{
  "name": "@helix/game",
  "version": "0.0.0",
  "private": true,
  "description": "Strand Descent — Phaser game (main app)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:demo": "vite build --mode demo",
    "build:ios": "vite build && npx cap sync ios && npx cap open ios",
    "build:android": "vite build && npx cap sync android && npx cap open android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:determinism": "vitest run --reporter=verbose src/core/rng/determinism-replay.test.ts",
    "validate:content": "vitest run --reporter=verbose src/core/content/content-bundle.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/firebase-analytics": "^6.0.0",
    "@capacitor-community/firebase-crashlytics": "3.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@helix/balance": "workspace:*",
    "@helix/content": "workspace:*",
    "@helix/shared-types": "workspace:*",
    "firebase": "^12.14.0",
    "idb-keyval": "^6.2.0",
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
