{
  "name": "@helix/game",
  "version": "0.0.0",
  "private": true,
  "description": "Strand Descent — Phaser game (main app)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:demo": "vite build --mode demo",
    "build:ios": "vite build && npx cap sync ios && npx cap open ios",
    "build:android": "vite build && npx cap sync android && npx cap open android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:determinism": "vitest run --reporter=verbose src/core/rng/determinism-replay.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.80.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "idb-keyval": "^6.2.0",
    "@helix/shared-types": "workspace:*",
    "@helix/balance": "workspace:*",
    "@helix/content": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0",
    "typescript": "^5.4.0"
  }
}
