{
  "name": "@helix/functions",
  "version": "0.0.0",
  "private": true,
  "description": "Strand Descent — Firebase Cloud Functions (Node 20)",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "@helix/shared-types": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^1.5.0",
    "typescript": "^5.4.0"
  }
}
