{
  "name": "@helix/functions",
  "version": "0.0.0",
  "private": true,
  "description": "Strand Descent — Firebase Cloud Functions (Node 20)",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
